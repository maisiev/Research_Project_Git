      "source": [
        "def convert_expr_to_ensembl(expr_df, mapping_dict):\n",
        "    expr_df = expr_df.loc[expr_df.index.intersection(mapping_dict.keys())].copy()\n",
        "    expr_df.index = expr_df.index.map(mapping_dict)\n",
        "    expr_df = expr_df.groupby(expr_df.index).mean()\n",
        "    return expr_df"
      ]
    },
