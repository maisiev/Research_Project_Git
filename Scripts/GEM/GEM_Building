      "source": [
        "# Rebuild mapping\n",
        "import mygene\n",
        "mg = mygene.MyGeneInfo()\n",
        "\n",
        "all_ensembl = set()\n",
        "for ct in [\"KER1\", \"TCELL\"]:\n",
        "    csv_path = os.path.join(pooled_dir, \"PathwayGeneDrivers\", f\"GeneDrivers_perGene_{ct}.csv\")\n",
        "    df_tmp = pd.read_csv(csv_path)\n",
        "    all_ensembl.update(df_tmp[\"gene_ensembl\"].dropna().unique())\n",
        "\n",
        "results_mg = mg.querymany(list(all_ensembl), scopes=\"ensembl.gene\", fields=\"symbol\", species=\"human\")\n",
        "ens_to_symbol = {r[\"query\"]: r[\"symbol\"] for r in results_mg if \"symbol\" in r and not r.get(\"notfound\", False)}\n",
        "print(f\"Mapped: {len(ens_to_symbol)}\")\n",
        "\n",
        "import time\n",
        "from urllib.error import HTTPError\n",
        "\n",
        "def pubmed_hits(gene, extra_term, retries=3):\n",
        "    query = f\"{gene}[Gene Name] AND ({extra_term})\"\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            handle = Entrez.esearch(db=\"pubmed\", term=query, retmax=0)\n",
        "            return int(Entrez.read(handle)[\"Count\"])\n",
        "        except HTTPError as e:\n",
        "            if e.code == 429:\n",
        "                wait = 2 ** attempt  # 1s, 2s, 4s\n",
        "                print(f\"Rate limited on {gene}, waiting {wait}s...\")\n",
        "                time.sleep(wait)\n",
        "            else:\n",
        "                raise\n",
        "    return -1  # mark as failed after all retries\n",
        "\n",
        "# Novelty screen\n",
        "results = []\n",
        "\n",
        "for ct in [\"KER1\", \"TCELL\"]:\n",
        "    csv_path = os.path.join(pooled_dir, \"PathwayGeneDrivers\", f\"GeneDrivers_perGene_{ct}.csv\")\n",
        "    df = pd.read_csv(csv_path)\n",
        "    df[\"resolved_symbol\"] = df[\"gene_ensembl\"].map(lambda x: ens_to_symbol.get(x, None))\n",
        "    mapped = df[df[\"resolved_symbol\"].notna()].copy()\n",
        "\n",
        "    genes_df = mapped.groupby(\"resolved_symbol\").agg(\n",
        "        mean_flux_diff=(\"mean_flux_diff\", \"mean\"),\n",
        "        pathways=(\"pathway\", lambda x: \"; \".join(x.unique()))\n",
        "    ).reset_index()\n",
        "\n",
        "    for i, row in enumerate(genes_df.itertuples()):\n",
        "        gene = row.resolved_symbol\n",
        "        ad_hits = pubmed_hits(gene, \"atopic dermatitis\")\n",
        "        time.sleep(0.7)  # increased from 0.35\n",
        "        sa_hits = pubmed_hits(gene, \"Staphylococcus aureus skin\")\n",
        "        time.sleep(0.7)\n",
        "\n",
        "        results.append({\n",
        "            \"cell_type\":      ct,\n",
        "            \"gene\":           gene,\n",
        "            \"pathways\":       row.pathways,\n",
        "            \"mean_flux_diff\": row.mean_flux_diff,\n",
        "            \"AD_hits\":        ad_hits,\n",
        "            \"SA_hits\":        sa_hits,\n",
        "            \"total_hits\":     ad_hits + sa_hits,\n",
        "            \"novelty_score\":  1 / (ad_hits + sa_hits + 1)\n",
        "        })\n",
        "\n",
        "        # Save checkpoint every 50 genes\n",
        "        if i % 50 == 0:\n",
        "            pd.DataFrame(results).to_csv(\n",
        "                os.path.join(pooled_dir, \"gene_novelty_screen_checkpoint.csv\"), index=False\n",
        "            )\n",
        "            print(f\"{ct}: {i}/{len(genes_df)} done\")\n",
        "\n",
        "novelty_df = pd.DataFrame(results).sort_values([\"cell_type\", \"novelty_score\"], ascending=[True, False])\n",
        "novelty_df.to_csv(os.path.join(pooled_dir, \"gene_novelty_screen.csv\"), index=False)\n",
        "novelty_df.head(20)"
      ]
